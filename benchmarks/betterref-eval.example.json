{
  "cases": [
    {
      "id": "clean-prd-page",
      "report": "fixtures/clean/report.json",
      "guard": "fixtures/clean/guard-report.json",
      "prd": "fixtures/clean/prd-checklist.json",
      "expect": {
        "verdict": "pass",
        "hardFailPresent": false,
        "minPrdCompliance": 100
      }
    },
    {
      "id": "screenshot-as-ui-pressure",
      "report": "fixtures/screenshot-as-ui/report.json",
      "guard": "fixtures/screenshot-as-ui/guard-report.json",
      "expect": {
        "verdict": "fail",
        "hardFailPresent": true,
        "blockingReasonIncludes": ["reference_asset_used_in_source"]
      }
    },
    {
      "id": "longpage-section-pressure",
      "report": "fixtures/longpage-section/report.json",
      "guard": "fixtures/longpage-section/guard-report.json",
      "longpage": "fixtures/longpage-section/longpage-report.json",
      "expect": {
        "verdict": "fail",
        "hardFailPresent": true,
        "blockingReasonIncludes": ["long-page section promotions"]
      }
    },
    {
      "id": "asset-quality-pressure",
      "report": "fixtures/asset-quality/report.json",
      "guard": "fixtures/asset-quality/guard-report.json",
      "expect": {
        "verdict": "fail",
        "hardFailPresent": true,
        "blockingReasonIncludes": ["asset_quality_below_threshold"]
      }
    },
    {
      "id": "imagegen-pending-pressure",
      "report": "fixtures/imagegen-pending/report.json",
      "guard": "fixtures/imagegen-pending/guard-report.json",
      "assetPlan": "fixtures/imagegen-pending/asset-plan.json",
      "require": "assetplan",
      "expect": {
        "verdict": "fail",
        "hardFailPresent": true,
        "blockingReasonIncludes": ["asset plan item asset-001 is pending"]
      }
    },
    {
      "id": "imagegen-fake-pass-pressure",
      "report": "fixtures/imagegen-fake-pass/report.json",
      "guard": "fixtures/imagegen-fake-pass/guard-report.json",
      "assetPlan": "fixtures/imagegen-fake-pass/asset-plan.json",
      "require": "assetplan",
      "expect": {
        "verdict": "fail",
        "hardFailPresent": true,
        "blockingReasonIncludes": [
          "lacks generated/source asset evidence",
          "lacks verification metadata"
        ]
      }
    },
    {
      "id": "imagegen-missing-file-pressure",
      "report": "fixtures/imagegen-missing-file/report.json",
      "guard": "fixtures/imagegen-missing-file/guard-report.json",
      "assetPlan": "fixtures/imagegen-missing-file/asset-plan.json",
      "project": "fixtures/imagegen-missing-file/project",
      "require": "assetplan",
      "expect": {
        "verdict": "fail",
        "hardFailPresent": true,
        "blockingReasonIncludes": ["generated/source asset file is unreadable"]
      }
    },
    {
      "id": "imagegen-dimension-mismatch-pressure",
      "report": "fixtures/imagegen-dimension-mismatch/report.json",
      "guard": "fixtures/imagegen-dimension-mismatch/guard-report.json",
      "assetPlan": "fixtures/imagegen-dimension-mismatch/asset-plan.json",
      "project": "fixtures/imagegen-dimension-mismatch/project",
      "require": "assetplan",
      "expect": {
        "verdict": "fail",
        "hardFailPresent": true,
        "blockingReasonIncludes": [
          "claimed native width 128 does not match file width 64",
          "claimed native height 96 does not match file height 64"
        ]
      }
    },
    {
      "id": "imagegen-file-sharpness-pressure",
      "report": "fixtures/imagegen-file-sharpness/report.json",
      "guard": "fixtures/imagegen-file-sharpness/guard-report.json",
      "assetPlan": "fixtures/imagegen-file-sharpness/asset-plan.json",
      "project": "fixtures/imagegen-file-sharpness/project",
      "require": "assetplan",
      "expect": {
        "verdict": "fail",
        "hardFailPresent": true,
        "blockingReasonIncludes": [
          "actual file sharpness 0 is below 20"
        ]
      }
    },
    {
      "id": "missing-mobile-prd-pressure",
      "report": "fixtures/missing-mobile/report.json",
      "guard": "fixtures/missing-mobile/guard-report.json",
      "prd": "fixtures/missing-mobile/prd-checklist.json",
      "expect": {
        "verdict": "revise",
        "hardFailPresent": false,
        "blockingReasonIncludes": ["mobile-viewport"]
      }
    }
  ]
}
